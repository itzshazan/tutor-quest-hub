# ===================================
# SUPABASE CONFIGURATION
# ===================================
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGc...your_anon_key_here

# ===================================
# STRIPE CONFIGURATION  
# ===================================
# Get these from: https://dashboard.stripe.com/test/apikeys

VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...your_publishable_key

# ===================================
# EDGE FUNCTION SECRETS
# ===================================
# Set these in Supabase Dashboard → Edge Functions → Manage secrets
# DO NOT put these in .env file (they're server-side only)

# STRIPE_SECRET_KEY=sk_test_...your_secret_key
# STRIPE_WEBHOOK_SECRET=whsec_...from_stripe_webhook_endpoint
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...from_supabase_settings
# RESEND_API_KEY=re_...optional_for_emails
